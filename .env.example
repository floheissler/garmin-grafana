# Instance-specific configuration for garmin-grafana
# Copy this file to .env and edit the values for your instance.
# Docker Compose reads .env automatically from the project directory.

# Container names (must be globally unique across all Docker containers on the host)
GARMIN_CONTAINER_NAME=garmin-fetch-data
INFLUXDB_CONTAINER_NAME=influxdb
GRAFANA_CONTAINER_NAME=grafana

# Host ports (must not collide with other services on the host)
INFLUXDB_HOST_PORT=8086
GRAFANA_HOST_PORT=3001

# Garmin device pinning (prevents multi-device tag conflicts — see README)
GARMIN_DEVICENAME="Your Watch Model"
GARMIN_DEVICEID=0000000000
GARMIN_BPM_DEVICENAME="Your BPM Device"

# Timezone (valid TZ identifier, e.g. America/New_York, Europe/Berlin)
USER_TIMEZONE=Europe/Berlin

# USB backup subdirectory (under /mnt/usb-backup/, used by create-backup.sh)
# USB_BACKUP_SUBDIR=garmin-influxdb
